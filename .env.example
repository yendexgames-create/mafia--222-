# Railway Environment Variables
PORT=8080
NODE_ENV=production

# MongoDB Atlas Connection
# IMPORTANT: Replace <username> and <password> with your actual MongoDB credentials
# Get this from MongoDB Atlas → Connect → Connect your application
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.zcf33yo.mongodb.net/?appName=Cluster0

# Security (generate random strings for production)
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production
SESSION_SECRET=your_session_secret_here_change_this_in_production

# Database settings
ALLOW_IN_MEMORY=true
MONGODB_TLS_ALLOW_INVALID=true

# Railway-specific settings
RAILWAY_ENVIRONMENT=production
RAILWAY_SERVICE_NAME=mafiaarena